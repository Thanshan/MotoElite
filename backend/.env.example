# ═══════════════════════════════════════════════════
#  MotoElite Motorbike Showroom — Environment Variables
#  Copy this file to .env and fill in your values
#  $ cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────
# Port the Express server will listen on
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────
# Local MongoDB URI (default)
MONGODB_URI=mongodb://localhost:27017/motorbike_showroom

# MongoDB Atlas URI (uncomment and replace for cloud deployment)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/motorbike_showroom?retryWrites=true&w=majority

# ─── JWT Authentication ─────────────────────────────
# Secret key for signing JWT tokens — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars

# Token expiry duration (e.g. 7d, 24h, 30m)
JWT_EXPIRE=7d

# ─── File Uploads ──────────────────────────────────
# Max file size for image uploads in bytes (default 5MB)
MAX_FILE_SIZE=5242880

# ─── CORS ──────────────────────────────────────────
# Allowed frontend origin(s) — comma-separated for multiple
# In development, use * or http://localhost:3000
CORS_ORIGIN=*

# ─── Admin Credentials (used by seed.js) ────────────
# These are only used when seeding the database
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@motoelite.in
ADMIN_PASSWORD=Admin@123
